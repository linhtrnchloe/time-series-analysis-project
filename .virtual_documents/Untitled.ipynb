from scipy import stats

def calculate_var(conditional_vol, mu, nu, alpha):
    # Student-t quantile (standardized)
    q = stats.t.ppf(alpha, nu) * np.sqrt((nu-2)/nu)
    var = mu + conditional_vol * q
    return var

